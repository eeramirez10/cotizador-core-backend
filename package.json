{
  "name": "cotizador-core-backend",
  "version": "1.0.0",
  "description": "Core backend for quoting domain",
  "main": "dist/presentation/server.js",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/presentation/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "start": "NODE_ENV=production node dist/presentation/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "NODE_ENV=development prisma migrate dev --name init",
    "prisma:seed": "NODE_ENV=development prisma db seed",
    "prisma:deploy": "NODE_ENV=production prisma migrate deploy",
    "prisma:studio": "NODE_ENV=development prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "env-var": "^7.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.2",
    "prisma": "^7.0.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

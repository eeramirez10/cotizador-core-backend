generator client {
  provider = "prisma-client"
  output   = "../src/infrastructure/database/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SELLER
  MANAGER
}

enum CustomerProfileStatus {
  PROSPECT
  FISCAL_COMPLETED
}

enum CustomerSource {
  ERP
  LOCAL
}

enum ProductSource {
  ERP
  LOCAL_TEMP
}

enum Currency {
  MXN
  USD
}

enum QuoteStatus {
  DRAFT
  PENDING
  QUOTED
  APPROVED
  REJECTED
  CANCELLED
}

enum QuoteOrigin {
  MANUAL
  FILE_UPLOAD
  TEXT_INPUT
}

enum QuoteDeliveryStatus {
  NOT_SENT
  SENT
}

enum QuoteDeliveryChannel {
  WHATSAPP
  EMAIL
}

enum QuoteDeliveryAttemptStatus {
  SENT
  FAILED
}

enum OrderGenerationStatus {
  NOT_GENERATED
  GENERATED
}

enum ErpTransferStatus {
  PENDING_UPLOAD
  UPLOADING
  UPLOADED
  FAILED
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(10)
  name      String   @db.VarChar(120)
  address   String?  @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users    User[]
  quotes   Quote[]
  products Product[]

  @@map("branches")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  firstName    String   @map("first_name") @db.VarChar(120)
  lastName     String   @map("last_name") @db.VarChar(120)
  username     String   @unique @db.VarChar(80)
  email        String   @unique @db.VarChar(160)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole
  isActive     Boolean  @default(true) @map("is_active")
  phone        String?  @db.VarChar(40)
  branchId     String   @map("branch_id") @db.Uuid
  erpUserCode String?   @unique @map("erp_user_code") @db.VarChar(80)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  createdCustomers Customer[] @relation("CustomerCreatedBy")
  updatedCustomers Customer[] @relation("CustomerUpdatedBy")
  createdProducts  Product[]  @relation("ProductCreatedBy")
  updatedProducts  Product[]  @relation("ProductUpdatedBy")
  createdQuotes    Quote[]    @relation("QuoteCreatedBy")
  updatedQuotes    Quote[]    @relation("QuoteUpdatedBy")
  quoteDeliveryAttempts QuoteDeliveryAttempt[] @relation("QuoteDeliveryAttemptSentBy")
  quoteOrderExports  QuoteOrderExport[] @relation("QuoteOrderExportGeneratedBy")
  quoteEvents      QuoteEvent[] @relation("QuoteEventActor")
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[] @relation("AuditLogActor")

  @@index([branchId])
  @@map("users")
}

model Customer {
  id               String                @id @default(uuid()) @db.Uuid
  source           CustomerSource        @default(LOCAL)
  externalId       String?               @map("external_id") @db.VarChar(120)
  externalSystem   String?               @map("external_system") @db.VarChar(80)
  code             String?               @db.VarChar(80)
  firstName        String                @map("first_name") @db.VarChar(120)
  lastName         String                @map("last_name") @db.VarChar(120)
  displayName      String                @map("display_name") @db.VarChar(260)
  legalName        String?               @map("legal_name") @db.VarChar(260)
  email            String?               @db.VarChar(160)
  phone            String?               @db.VarChar(40)
  whatsapp         String                @db.VarChar(40)
  taxId            String?               @map("tax_id") @db.VarChar(60)
  taxRegime        String?               @map("tax_regime") @db.VarChar(120)
  billingStreet    String?               @map("billing_street") @db.VarChar(255)
  billingCity      String?               @map("billing_city") @db.VarChar(120)
  billingState     String?               @map("billing_state") @db.VarChar(120)
  billingPostalCode String?              @map("billing_postal_code") @db.VarChar(20)
  billingCountry   String?               @map("billing_country") @db.VarChar(80)
  profileStatus    CustomerProfileStatus @default(PROSPECT) @map("profile_status")
  isActive         Boolean               @default(true) @map("is_active")
  notes            String?               @db.Text
  createdByUserId  String?               @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?               @map("updated_by_user_id") @db.Uuid
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  createdByUser User? @relation("CustomerCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("CustomerUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  contacts CustomerContact[]
  quotes   Quote[]

  @@index([externalId])
  @@index([code])
  @@index([displayName])
  @@index([whatsapp])
  @@map("customers")
}

model CustomerContact {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  name       String   @db.VarChar(160)
  jobTitle   String?  @map("job_title") @db.VarChar(120)
  email      String?  @db.VarChar(160)
  phone      String?  @db.VarChar(40)
  mobile     String?  @db.VarChar(40)
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_contacts")
}

model Product {
  id             String      @id @default(uuid()) @db.Uuid
  source         ProductSource @default(LOCAL_TEMP)
  externalId     String?     @map("external_id") @db.VarChar(120)
  externalSystem String?     @map("external_system") @db.VarChar(80)
  code           String?     @db.VarChar(80)
  ean            String?     @db.VarChar(120)
  description    String      @db.VarChar(500)
  unit           String      @db.VarChar(30)
  currency       Currency    @default(USD)
  averageCost    Decimal?    @map("average_cost") @db.Decimal(14, 4)
  lastCost       Decimal?    @map("last_cost") @db.Decimal(14, 4)
  stock          Decimal?    @db.Decimal(14, 4)
  branchId       String?     @map("branch_id") @db.Uuid
  isActive       Boolean     @default(true) @map("is_active")
  createdByUserId String?    @map("created_by_user_id") @db.Uuid
  updatedByUserId String?    @map("updated_by_user_id") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  branch       Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdByUser User?  @relation("ProductCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?  @relation("ProductUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  quoteItems QuoteItem[]

  @@index([code])
  @@index([ean])
  @@index([description])
  @@index([branchId])
  @@map("products")
}

model Quote {
  id               String     @id @default(uuid()) @db.Uuid
  quoteNumber      String     @unique @map("quote_number") @db.VarChar(40)
  status           QuoteStatus @default(DRAFT)
  deliveryStatus   QuoteDeliveryStatus @default(NOT_SENT) @map("delivery_status")
  firstSentAt      DateTime?  @map("first_sent_at")
  orderStatus      OrderGenerationStatus @default(NOT_GENERATED) @map("order_status")
  orderGeneratedAt DateTime?  @map("order_generated_at")
  orderReference   String?    @unique @map("order_reference") @db.VarChar(80)
  origin           QuoteOrigin @default(MANUAL)
  currency         Currency
  exchangeRate     Decimal    @map("exchange_rate") @db.Decimal(14, 6)
  exchangeRateDate DateTime   @map("exchange_rate_date") @db.Date
  taxRate          Decimal    @map("tax_rate") @db.Decimal(8, 6)
  subtotal         Decimal    @db.Decimal(14, 4)
  tax              Decimal    @db.Decimal(14, 4)
  total            Decimal    @db.Decimal(14, 4)
  deliveryPlace    String?    @map("delivery_place") @db.VarChar(255)
  paymentTerms     String     @default("CONTADO") @map("payment_terms") @db.VarChar(220)
  validityDays     Int        @default(10) @map("validity_days")
  validUntil       DateTime   @map("valid_until") @db.Date
  branchId         String     @map("branch_id") @db.Uuid
  customerId       String     @map("customer_id") @db.Uuid
  createdByUserId  String     @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?    @map("updated_by_user_id") @db.Uuid
  notes            String?    @db.Text
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdByUser User     @relation("QuoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser User?    @relation("QuoteUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  items  QuoteItem[]
  deliveryAttempts QuoteDeliveryAttempt[]
  orderExports QuoteOrderExport[]
  events QuoteEvent[]

  @@index([status])
  @@index([deliveryStatus])
  @@index([orderStatus])
  @@index([branchId])
  @@index([customerId])
  @@index([createdByUserId])
  @@map("quotes")
}

model QuoteItem {
  id                   String   @id @default(uuid()) @db.Uuid
  quoteId              String   @map("quote_id") @db.Uuid
  productId            String?  @map("product_id") @db.Uuid
  externalProductCode  String?  @map("external_product_code") @db.VarChar(80)
  ean                  String?  @db.VarChar(120)
  customerDescription  String?  @map("customer_description") @db.VarChar(500)
  customerUnit         String?  @map("customer_unit") @db.VarChar(30)
  erpDescription       String?  @map("erp_description") @db.VarChar(500)
  unit                 String   @db.VarChar(30)
  qty                  Decimal  @db.Decimal(14, 4)
  stock                Decimal? @db.Decimal(14, 4)
  deliveryTime         String?  @map("delivery_time") @db.VarChar(80)
  cost                 Decimal  @db.Decimal(14, 4)
  costCurrency         Currency @map("cost_currency")
  marginPct            Decimal  @map("margin_pct") @db.Decimal(10, 4)
  unitPrice            Decimal  @map("unit_price") @db.Decimal(14, 4)
  subtotal             Decimal  @db.Decimal(14, 4)
  sourceRequiresReview Boolean  @default(false) @map("source_requires_review")
  requiresReview       Boolean  @default(false) @map("requires_review")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([productId])
  @@map("quote_items")
}

model QuoteEvent {
  id          String     @id @default(uuid()) @db.Uuid
  quoteId     String     @map("quote_id") @db.Uuid
  status      QuoteStatus
  note        String?    @db.Text
  actorUserId String?    @map("actor_user_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")

  quote     Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  actorUser User? @relation("QuoteEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([createdAt])
  @@map("quote_events")
}

model QuoteDeliveryAttempt {
  id                String                   @id @default(uuid()) @db.Uuid
  quoteId           String                   @map("quote_id") @db.Uuid
  channel           QuoteDeliveryChannel
  recipient         String                   @db.VarChar(180)
  status            QuoteDeliveryAttemptStatus
  providerMessageId String?                  @map("provider_message_id") @db.VarChar(160)
  errorMessage      String?                  @map("error_message") @db.Text
  sentByUserId      String?                  @map("sent_by_user_id") @db.Uuid
  sentAt            DateTime                 @map("sent_at")
  createdAt         DateTime                 @default(now()) @map("created_at")

  quote      Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sentByUser User? @relation("QuoteDeliveryAttemptSentBy", fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([sentAt])
  @@map("quote_delivery_attempts")
}

model QuoteOrderExport {
  id                String            @id @default(uuid()) @db.Uuid
  quoteId           String            @map("quote_id") @db.Uuid
  orderReference    String            @map("order_reference") @db.VarChar(80)
  fileName          String            @map("file_name") @db.VarChar(180)
  transferStatus    ErpTransferStatus @default(PENDING_UPLOAD) @map("transfer_status")
  generatedByUserId String?           @map("generated_by_user_id") @db.Uuid
  generatedAt       DateTime          @map("generated_at")
  uploadedAt        DateTime?         @map("uploaded_at")
  remotePath        String?           @map("remote_path") @db.VarChar(260)
  lastError         String?           @map("last_error") @db.Text
  createdAt         DateTime          @default(now()) @map("created_at")

  quote           Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  generatedByUser User? @relation("QuoteOrderExportGeneratedBy", fields: [generatedByUserId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([transferStatus])
  @@index([generatedAt])
  @@map("quote_order_exports")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  entityType  String   @map("entity_type") @db.VarChar(80)
  entityId    String   @map("entity_id") @db.VarChar(120)
  action      String   @db.VarChar(80)
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actorUser User? @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

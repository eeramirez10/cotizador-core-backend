@quoteItemId = REPLACE_QUOTE_ITEM_ID

### Create quote (seller/manager uses own branch)
POST {{baseUrl}}/quotes
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "customerId": "9b6430a2-2562-4c48-9b2c-7d6c2f1b42c9",
  "origin": "MANUAL",
  "currency": "MXN",
  "exchangeRate": 1,
  "exchangeRateDate": "2026-03-03",
  "taxRate": 0.16,
  "notes": "Initial quote"
}

### Create quote from extracted items (file/text)
POST {{baseUrl}}/quotes/from-extraction
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "customerId": "REPLACE_CUSTOMER_ID",
  "origin": "FILE_UPLOAD",
  "currency": "USD",
  "exchangeRate": 17.30,
  "exchangeRateDate": "2026-03-05",
  "taxRate": 0.16,
  "notes": "Generated from extracted request",
  "items": [
    {
      "description_original": "VALVULA CHECK WAFER 4\"",
      "description_normalizada": "valvula check wafer 4 pulg",
      "cantidad": 6,
      "unidad_original": "PZA",
      "unidad_normalizada": "PZA",
      "requiere_revision": false
    },
    {
      "description_original": "TUBO CED 40",
      "description_normalizada": "tubo ced 40",
      "cantidad": null,
      "unidad_original": null,
      "unidad_normalizada": null,
      "requiere_revision": true
    }
  ]
}

### Create quote for a specific branch (ADMIN only)
POST {{baseUrl}}/quotes
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "customerId": "REPLACE_CUSTOMER_ID",
  "branchCode": "02",
  "origin": "MANUAL",
  "currency": "USD",
  "exchangeRate": 17.3,
  "exchangeRateDate": "2026-03-03",
  "taxRate": 0.16,
  "notes": "Admin created quote for MTY branch"
}

### List quotes (admin filter by status + branch)
GET {{baseUrl}}/quotes?page=1&pageSize=10&status=DRAFT&search=&branchCode=02
Authorization: Bearer {{jwt}}

### List quotes (manager scoped to own branch)
GET {{baseUrl}}/quotes?page=1&pageSize=10
Authorization: Bearer {{managerJwt}}

### Get quote by id
GET {{baseUrl}}/quotes/{{quoteId}}
Authorization: Bearer {{jwt}}

### Add quote item
POST {{baseUrl}}/quotes/{{quoteId}}/items
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "productId": null,
  "externalProductCode": null,
  "ean": null,
  "customerDescription": "valvula check 2 pulgadas",
  "customerUnit": "PZA",
  "erpDescription": null,
  "unit": "PZA",
  "qty": 10,
  "stock": 0,
  "deliveryTime": "2-4 weeks",
  "cost": 100,
  "costCurrency": "USD",
  "marginPct": 15,
  "sourceRequiresReview": false,
  "requiresReview": false
}

### Match ERP product to extracted/manual item
PATCH {{baseUrl}}/quotes/{{quoteId}}/items/{{quoteItemId}}/match-erp
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "productId": null,
  "externalProductCode": "01300938",
  "ean": "TSC480",
  "erpDescription": "TUBO DE ACERO AL CARBON SIN COSTURA 114.3 X 08.6 MM. (4\" CED. 80)",
  "unit": "M",
  "stock": 267.89,
  "cost": 783.7069,
  "costCurrency": "USD",
  "qty": 6,
  "deliveryTime": "Immediate"
}

### Update quote item
PATCH {{baseUrl}}/quotes/{{quoteId}}/items/{{quoteItemId}}
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "qty": 12,
  "cost": 102.5
}

### Remove quote item
DELETE {{baseUrl}}/quotes/{{quoteId}}/items/{{quoteItemId}}
Authorization: Bearer {{jwt}}

### Update quote metadata
PATCH {{baseUrl}}/quotes/{{quoteId}}
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "notes": "Updated note from seller",
  "taxRate": 0.16
}

### Status transition: DRAFT -> PENDING
PATCH {{baseUrl}}/quotes/{{quoteId}}/status
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "status": "PENDING",
  "note": "Waiting internal approval"
}

### Status transition: PENDING -> QUOTED
PATCH {{baseUrl}}/quotes/{{quoteId}}/status
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "status": "QUOTED",
  "note": "Quoted and sent to customer"
}

### Status transition: QUOTED -> APPROVED
PATCH {{baseUrl}}/quotes/{{quoteId}}/status
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "status": "APPROVED",
  "note": "Customer accepted the quote"
}

### Generate order (quote must be QUOTED or APPROVED)
POST {{baseUrl}}/quotes/{{quoteId}}/generate-order
Authorization: Bearer {{jwt}}
